{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TableDetailResponse",
  "required": [
    "uri",
    "id",
    "name",
    "displayName",
    "transactional",
    "primaryKey",
    "indexKey",
    "distributionKey",
    "syntheticPrimaryKeyEnabled",
    "isAlias",
    "isAliasable",
    "isTyped",
    "tableType",
    "path",
    "columns",
    "columnMetadata",
    "attributes",
    "metadata",
    "bucket"
  ],
