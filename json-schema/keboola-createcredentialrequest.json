{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateCredentialRequest",
  "type": "object",
  "required": [
    "type",
    "permissions"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "ssh_key",
        "http_token"
      ]
    },
    "publicKey": {
      "type": "string",
      "description": "SSH public key. Required iff `type` is `ssh_key`; forbidden otherwise."
    },
    "name": {
      "type": "string",
      "default": "",
      "description": "Optional caller-supplied display label."
    },
    "permissions": {
      "type": "string",
      "enum": [
        "readOnly",
        "readWrite"
      ]
    }
  }
}