{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Credentials",
  "type": "object",
  "required": [
    "id",
    "branchId",
    "authorizedFor",
    "creator",
    "created",
    "oauthVersion",
    "appKey",
    "#appSecret",
    "#data"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "branchId": {
      "type": "string",
      "nullable": true
    },
    "authorizedFor": {
      "type": "string"
    },
    "creator": {
      "type": "object",
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "nullable": true
        }
      }
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "oauthVersion": {
      "type": "string"
    },
    "appKey": {
      "type": "string"
    },
    "#appSecret": {
      "type": "string"
    },
    "#data": {
      "type": "string"
    }
  }
}