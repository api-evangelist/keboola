{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Column",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Column name"
    },
    "type": {
      "type": "string",
      "description": "Column data type. Present only when onlyWorkspaceSchema parameter is set to \"1\"."
    }
  }
}