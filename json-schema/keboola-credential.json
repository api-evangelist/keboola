{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Credential",
  "type": "object",
  "required": [
    "id",
    "type",
    "name",
    "permissions",
    "ownerAdminId",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "enum": [
        "ssh_key",
        "http_token"
      ]
    },
    "name": {
      "type": "string"
    },
    "permissions": {
      "type": "string",
      "enum": [
        "readOnly",
        "readWrite"
      ]
    },
    "ownerAdminId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}