{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vendor",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "isPublic": {
      "type": "boolean"
    },
    "isApproved": {
      "type": "boolean"
    }
  }
}