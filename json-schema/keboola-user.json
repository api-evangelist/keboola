{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "vendors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "isAdmin": {
      "type": "boolean"
    }
  }
}