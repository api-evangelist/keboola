{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Error",
  "type": "object",
  "required": [
    "error",
    "code",
    "exceptionId",
    "status"
  ],
  "properties": {
    "error": {
      "type": "string"
    },
    "code": {
      "type": "integer"
    },
    "exceptionId": {
      "type": "string"
    },
    "status": {
      "enum": [
        "error"
      ]
    },
    "context": {
      "type": "object"
    }
  }
}