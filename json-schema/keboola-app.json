{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "App",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "vendor": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "extractor",
        "application",
        "writer",
        "processor",
        "code-pattern",
        "other",
        "transformation",
        "data-app"
      ]
    },
    "shortDescription": {
      "type": "string"
    },
    "longDescription": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "isPublic": {
      "type": "boolean"
    },
    "isApproved": {
      "type": "boolean"
    },
    "repository": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      }
    }
  }
}