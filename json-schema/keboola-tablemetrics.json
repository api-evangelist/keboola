{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TableMetrics",
  "type": "object",
  "properties": {
    "rowCount": {
      "type": "integer",
      "nullable": true,
      "description": "Number of rows in the table"
    },
    "byteSize": {
      "type": "integer",
      "nullable": true,
      "description": "Size of the table in bytes"
    }
  }
}